{
    "name": "peppermint/ai-brain-bridge",
    "description": "Einheitlicher Kommunikationslayer (MCP + Events) zwischen Peppermint-Produkten und AI Brain.",
    "type": "library",
    "license": "proprietary",
    "keywords": ["peppermint", "ai-brain", "mcp", "events", "integration"],
    "require": {
        "php": "^8.3",
        "guzzlehttp/guzzle": "^7.8",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "Peppermint\\AiBrainBridge\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Peppermint\\AiBrainBridge\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Peppermint\\AiBrainBridge\\AiBrainBridgeServiceProvider"
            ],
            "aliases": {
                "AiBrain": "Peppermint\\AiBrainBridge\\Facades\\AiBrain"
            }
        }
    },
    "scripts": {
        "test": "pest"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
